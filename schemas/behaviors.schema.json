{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://raw.githubusercontent.com/YUYA556223/PalSmith/main/schemas/behaviors.schema.json",
    "title": "PalSmith behaviors (palsmith/behaviors.jsonc)",
    "type": "object",
    "properties": {
        "$schema": { "type": "string" }
    },
    "additionalProperties": {
        "type": "object",
        "description": "Key: namespaced id ('mypack:Thing') or literal game id ('Wood').",
        "properties": {
            "onUse": { "$ref": "#/definitions/actionList" },
            "onPlace": { "$ref": "#/definitions/actionList" },
            "onInteract": { "$ref": "#/definitions/actionList" }
        },
        "additionalProperties": false
    },
    "definitions": {
        "actionList": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/definitions/action" }
        },
        "action": {
            "type": "object",
            "required": ["action"],
            "properties": {
                "action": {
                    "type": "string",
                    "enum": ["announce", "give_item", "spawn_pal", "spawn_mesh"],
                    "description": "Handler name. Additional handlers can be registered from Lua via PalSmith.registerAction."
                },
                "text": { "type": "string", "description": "announce: message ({id}, {event}, {pack} templates)." },
                "item": { "type": "string", "description": "give_item: namespaced or literal item id." },
                "count": { "type": "integer", "minimum": 1 },
                "pal": { "type": "string", "description": "spawn_pal: character id (e.g. Kitsunebi)." },
                "level": { "type": "integer", "minimum": 1 },
                "model": { "type": "string", "description": "spawn_mesh: OBJ path relative to the palsmith/ folder." },
                "scale": { "type": "number" },
                "offset": { "$ref": "#/definitions/vec3" },
                "cooldownSec": { "type": "number", "minimum": 0, "description": "Minimum seconds between firings of this behavior." }
            },
            "additionalProperties": true
        },
        "vec3": {
            "type": "object",
            "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" },
                "z": { "type": "number" }
            },
            "additionalProperties": false
        }
    }
}
